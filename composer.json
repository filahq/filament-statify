{
  "name": "filahq/statify",
  "description": "Export your Filament stat widgets as API.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "filament",
    "laravel",
    "widget",
    "stats",
    "api"
  ],
  "suggest": {
    "filament/filament": "Required if you want to use StatifyPlugin with a Filament panel provider.",
    "laravel/sanctum": "Required if you configure STATIFY_GUARD=sanctum."
  },
  "require": {
    "php": "^8.2",
    "filament/widgets": "^4.0",
    "illuminate/support": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "FilaHQ\\Statify\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FilaHQ\\Statify\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "FilaHQ\\Statify\\StatifyServiceProvider"
      ]
    }
  }
}
