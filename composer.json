{
    "name": "filahq/statify",
    "description": "Export your Filament stat widgets as API.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/support": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "FilaHQ\\Statify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FilaHQ\\Statify\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilaHQ\\Statify\\StatifyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
